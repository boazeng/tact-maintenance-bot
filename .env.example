# takt-bots reads secrets from the SHARED env file, NOT from this file:
#   C:\Users\User\Aiprojects\env\.env
# (override the location with TAKT_SHARED_ENV). This file only documents which
# variables the platform uses. Do not duplicate secret values here.

# ── Storage ──────────────────────────────────────────────────
# sqlite (local, default) | dynamodb (AWS, for production)
STORAGE_BACKEND=sqlite
# Local SQLite file location (default: <repo>/data/takt-bots.db)
# BOT_DB_PATH=

# ── AI script generation (Anthropic) — from shared env ───────
# ANTHROPIC_API_KEY=
# CLAUDE_MODEL=claude-sonnet-4-6

# ── WhatsApp Cloud API (Meta) — from shared env ──────────────
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_VERIFY_TOKEN=

# ── Service-Call app (open the bot's call in your own app) ────
# The tester's write-target "servicecall" POSTs to this app's bot-ingest API.
# Run service-call on a NON-8020 port (8020 is takt-bots): uvicorn ... --port 8021
# SERVICE_CALL_URL=http://localhost:8021
# A bot API key created in the Service-Call app (format: sccall_...)
# SERVICE_CALL_API_KEY=
# Branch stamped on new calls: 026 = maintenance (default), 110 = energy
# SERVICE_CALL_BRANCH=026

# ── Telegram Bot API — from shared env ───────────────────────
# Token from @BotFather. Used by run_telegram_guy.py (long polling).
# TELEGRAM_BOT_TOKEN=
# Which script the Telegram channel runs (default: guy-parking-service)
# TELEGRAM_SCRIPT_ID=guy-parking-service

# ── Bot routing — which script new sessions run ──────────────
# ROUTING_SCRIPT_ID=maintenance-troubleshoot
# VOICE_BOT_PHONES=   (empty = every message uses the interactive flow)

# ── DynamoDB table names (only when STORAGE_BACKEND=dynamodb) ─
# AWS_REGION=us-east-1
# BOT_SCRIPTS_TABLE=takt-bots-scripts
# TROUBLESHOOT_SESSIONS_TABLE=takt-bots-sessions
# MESSAGES_TABLE=takt-bots-messages
# SERVICE_CALLS_TABLE=takt-bots-service-calls
# BOT_PROMPTS_TABLE=takt-bots-prompts

# ── Optional pluggable integrations (off by default) ─────────
# EQUIPMENT_READER_ENABLED=false
# BOT_EQUIPMENT_READER_MODULE=
# SERVICE_CALL_WRITER_ENABLED=false
# BOT_SERVICE_CALL_WRITER_MODULE=
# LLM_IDENTIFIER_ENABLED=false
# BOT_LLM_IDENTIFIER_MODULE=
# OPENAI_API_KEY=         (used by instruction-step LLM routing, optional)
# OPENAI_MODEL=gpt-4o-mini
